---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <div class="footer-logo">
        <img src="/JG-Concrete-Pumping/Screenshot_2026-03-10_171154-removebg-preview.png" alt="JG Concrete Pumping" class="footer-logo-img" />
        <span>JG Concrete Pumping</span>
      </div>
      <p>Owner-operated 38-meter boom pump service serving the Dallas–East Texas Corridor in Texas. Residential, commercial, and civil concrete pumping.</p>
    </div>

    <div class="footer-links">
      <h4>Services</h4>
      <ul>
        <li><a href="/#services">Residential Pours</a></li>
        <li><a href="/#services">Commercial & Industrial</a></li>
        <li><a href="/#services">Pool Decks</a></li>
        <li><a href="/#services">Civil Pours</a></li>
      </ul>
    </div>

    <div class="footer-links">
      <h4>Quick Links</h4>
      <ul>
        <li><a href="/#about">About Jacob</a></li>
        <li><a href="/#service-area">Service Area</a></li>
        <li><a href="/#contact">Contact</a></li>
      </ul>
      <a href="https://www.facebook.com/profile.php?id=61587739823331" target="_blank" rel="noopener noreferrer" class="fb-footer-link">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        Facebook
      </a>
    </div>

    <div class="footer-contact">
      <h4>Contact</h4>
      <p>
        <strong>Phone:</strong><br />
        <a href="tel:+14697044227">(469) 704-4227</a>
      </p>
      <p>
        <strong>Email:</strong><br />
        <a href="mailto:Jacob@gordonconcrete.com">Jacob@gordonconcrete.com</a>
      </p>
      <p>
        <strong>Service Area:</strong><br />
        Dallas–Fort Worth & East Texas
      </p>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container">
      <p>&copy; {year} JG Concrete Pumping. All rights reserved. | Dallas–East Texas Corridor, Texas</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-primary-dark);
    color: rgba(255,255,255,0.8);
    margin-top: auto;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1.5fr;
    gap: 2.5rem;
    padding: 3.5rem 1.5rem 3rem;
  }

  .footer-brand .footer-logo {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 1rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 1rem;
  }

  .footer-logo-img {
    height: 36px;
    width: auto;
    flex-shrink: 0;
  }

  .footer-brand p {
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .footer-links h4,
  .footer-contact h4 {
    color: #fff;
    font-size: 0.85rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  .footer-links ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-links a {
    color: rgba(255,255,255,0.7);
    font-size: 0.9rem;
    transition: color 0.15s;
  }

  .footer-links a:hover {
    color: #fff;
    text-decoration: none;
  }

  .footer-contact p {
    font-size: 0.9rem;
    margin-bottom: 0.75rem;
  }

  .footer-contact a {
    color: var(--color-accent);
  }

  .footer-contact a:hover {
    color: #fff;
  }

  .fb-footer-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: rgba(255,255,255,0.6);
    font-size: 0.85rem;
    margin-top: 1rem;
    transition: color 0.15s;
  }

  .fb-footer-link:hover {
    color: #fff;
    text-decoration: none;
  }

  .footer-bottom {
    border-top: 1px solid rgba(255,255,255,0.1);
    padding: 1.25rem 0;
    text-align: center;
    font-size: 0.82rem;
    color: rgba(255,255,255,0.5);
  }

  @media (max-width: 860px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }

    .footer-brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 480px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
