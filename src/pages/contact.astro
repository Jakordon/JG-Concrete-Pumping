---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact"
  description="Contact Gordon Concrete Pumping for a free quote. Dallas–Tyler Corridor, Texas. 38-meter boom pump, residential and commercial concrete pumping."
>

  <div class="page-hero">
    <div class="container">
      <span class="section-label">Get in Touch</span>
      <h1>Contact Us</h1>
      <p>Ready to book a pour or need a quote? Reach out directly — you'll speak with the operator.</p>
    </div>
  </div>

  <section class="section">
    <div class="container contact-layout">

      <!-- Contact Info -->
      <div class="contact-info">
        <h2>Direct Contact</h2>
        <p>We don't route calls through a switchboard. Call or text the operator directly.</p>

        <div class="contact-methods">
          <div class="contact-method">
            <div class="contact-method-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg></div>
            <div>
              <strong>Phone / Text</strong>
              <a href="tel:+14697044227">(469) 704-4227</a>
              <span class="contact-note">Fastest way to book. Call or text anytime.</span>
            </div>
          </div>
          <div class="contact-method">
            <div class="contact-method-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg></div>
            <div>
              <strong>Email</strong>
              <a href="mailto:Jacob@gordonconcrete.com">Jacob@gordonconcrete.com</a>
              <span class="contact-note">For quotes and job details via email.</span>
            </div>
          </div>
          <div class="contact-method">
            <div class="contact-method-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg></div>
            <div>
              <strong>Service Area</strong>
              <span>Dallas–Fort Worth Metroplex & Tyler / East Texas</span>
              <span class="contact-note">I-20 corridor, North Texas</span>
            </div>
          </div>
        </div>

        <div class="quote-checklist">
          <h4>What to Have Ready When You Call</h4>
          <ul>
            <li>Site address or suburb</li>
            <li>Estimated pour volume (cubic yards)</li>
            <li>Type of pour (slab, footing, wall, floor, etc.)</li>
            <li>Preferred date(s)</li>
            <li>Ready-mix supplier you're using</li>
            <li>Any site access constraints</li>
          </ul>
        </div>

        <div class="response-note">
          <strong>Response Time:</strong> We aim to respond to all enquiries within a few hours during business hours. For urgent jobs, call directly.
        </div>
      </div>

      <!-- Quote Form -->
      <div class="contact-form-wrap">
        <h2>Request a Quote</h2>
        <p>Fill in your details and we'll get back to you with a price.</p>

        <form class="quote-form" name="quote-request" method="POST" action="/contact/success">
          <div class="form-row">
            <div class="form-group">
              <label for="name">Your Name *</label>
              <input type="text" id="name" name="name" placeholder="John Smith" required />
            </div>
            <div class="form-group">
              <label for="phone">Phone Number *</label>
              <input type="tel" id="phone" name="phone" placeholder="(469) 704-4227" required />
            </div>
          </div>

          <div class="form-group">
            <label for="email">Email Address</label>
            <input type="email" id="email" name="email" placeholder="your@email.com" />
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="site-address">Site Address / Suburb *</label>
              <input type="text" id="site-address" name="site_address" placeholder="Dallas, TX" required />
            </div>
            <div class="form-group">
              <label for="pour-date">Preferred Pour Date *</label>
              <input type="date" id="pour-date" name="pour_date" required />
            </div>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="pour-type">Type of Pour *</label>
              <select id="pour-type" name="pour_type" required>
                <option value="" disabled selected>Select type...</option>
                <option value="residential-slab">Residential Slab / Footing</option>
                <option value="driveway">Driveway / Path</option>
                <option value="townhouse">Townhouse / Duplex / Multi-Unit</option>
                <option value="commercial-floor">Commercial / Industrial Floor</option>
                <option value="tilt-panel">Tilt-Panel Construction</option>
                <option value="pool">Pool Surround</option>
                <option value="retaining-wall">Retaining Wall</option>
                <option value="civil">Civil / Structural</option>
                <option value="other">Other</option>
              </select>
            </div>
            <div class="form-group">
              <label for="pour-volume">Estimated Volume (yd³)</label>
              <input type="number" id="pour-volume" name="pour_volume" placeholder="e.g. 30" min="1" />
            </div>
          </div>

          <div class="form-group">
            <label for="message">Additional Details</label>
            <textarea id="message" name="message" rows="4" placeholder="Site access notes, concrete supplier, any other details..."></textarea>
          </div>

          <button type="submit" class="btn btn-primary btn-submit">Send Quote Request</button>

          <p class="form-disclaimer">
            We'll respond by phone or email within a few hours. For urgent bookings, call us directly.
          </p>
        </form>
      </div>

    </div>
  </section>

  <!-- Tyler Note -->
  <section class="section section--alt">
    <div class="container">
      <div class="tyler-scheduling-note">
        <div class="tsn-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg></div>
        <div>
          <h4>Booking Tyler / East Texas Jobs</h4>
          <p>
            Tyler area jobs are batched to a minimum of 2 per trip to keep the ~100-mile run economical
            at current diesel prices. If you're in the Tyler area, contact us as early as possible so we
            can coordinate scheduling with other jobs on the same day. We'll always confirm trip feasibility
            before committing.
          </p>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  .contact-layout {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 4rem;
    align-items: flex-start;
  }

  .contact-info h2,
  .contact-form-wrap h2 {
    color: var(--color-primary);
    margin-bottom: 0.5rem;
  }

  .contact-info > p,
  .contact-form-wrap > p {
    color: var(--color-text-muted);
    margin-bottom: 1.75rem;
  }

  .contact-methods {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-bottom: 2rem;
  }

  .contact-method {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .contact-method-icon {
    font-size: 1.5rem;
    flex-shrink: 0;
  }

  .contact-method strong {
    display: block;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    margin-bottom: 0.15rem;
  }

  .contact-method a {
    display: block;
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 0.15rem;
  }

  .contact-method a:hover {
    color: var(--color-accent);
  }

  .contact-method span {
    display: block;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 0.15rem;
  }

  .contact-note {
    font-size: 0.82rem !important;
    color: var(--color-text-muted) !important;
    font-weight: 400 !important;
  }

  .quote-checklist {
    background: #f0f4f8;
    border-radius: var(--radius);
    padding: 1.25rem 1.5rem;
    margin-bottom: 1.25rem;
  }

  .quote-checklist h4 {
    color: var(--color-primary);
    margin-bottom: 0.75rem;
    font-size: 0.9rem;
  }

  .quote-checklist ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .quote-checklist li {
    font-size: 0.88rem;
    display: flex;
    gap: 0.5rem;
    color: var(--color-text-muted);
  }

  .quote-checklist li::before {
    content: '✓';
    color: var(--color-accent);
    font-weight: 700;
  }

  .response-note {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    background: #fff8ed;
    border-left: 3px solid var(--color-accent);
    padding: 0.75rem 1rem;
    border-radius: 0 var(--radius) var(--radius) 0;
  }

  /* Form */
  .contact-form-wrap {
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    padding: 2.5rem;
    box-shadow: var(--shadow-lg);
  }

  .quote-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .form-group label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius);
    padding: 0.65rem 0.85rem;
    font-size: 0.95rem;
    font-family: var(--font-sans);
    background: var(--color-bg);
    color: var(--color-text);
    transition: border-color 0.15s;
    width: 100%;
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--color-accent);
    background: #fff;
  }

  .form-group textarea {
    resize: vertical;
    min-height: 100px;
  }

  .btn-submit {
    width: 100%;
    font-size: 1.05rem;
    padding: 1rem;
    margin-top: 0.5rem;
  }

  .form-disclaimer {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    text-align: center;
    margin: 0;
  }

  /* Tyler Note */
  .tyler-scheduling-note {
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    padding: 1.75rem 2rem;
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
    box-shadow: var(--shadow);
    border-left: 4px solid var(--color-accent);
  }

  .tsn-icon {
    font-size: 1.75rem;
    flex-shrink: 0;
  }

  .tyler-scheduling-note h4 {
    color: var(--color-primary);
    margin-bottom: 0.4rem;
  }

  .tyler-scheduling-note p {
    font-size: 0.92rem;
    color: var(--color-text-muted);
    margin: 0;
  }

  @media (max-width: 860px) {
    .contact-layout {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .form-row {
      grid-template-columns: 1fr;
    }
  }
</style>
