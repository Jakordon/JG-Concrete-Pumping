---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Gordon Concrete Pumping | Dallas–Tyler, TX"
  description="Owner-operated 38-meter boom pump serving the Dallas–Tyler Corridor. Residential, commercial, and civil concrete pumping. Call Jacob at (469) 704-4227."
>

  <!-- ==============================
       HERO
  ============================== -->
  <section class="hero">
    <div class="container hero-inner">
      <span class="section-label">Dallas–Tyler Corridor, Texas</span>
      <h1>Concrete Pumping Done Right</h1>
      <p class="hero-sub">
        Owner-operated 38-meter boom pump serving the DFW Metroplex and Tyler, TX.
        Every job run personally by Jacob Gordon — Concrete Industry Management professional.
      </p>
      <div class="hero-actions">
        <a href="#contact" class="btn btn-primary">Get a Free Quote</a>
        <a href="tel:+14697044227" class="btn btn-outline">Call (469) 704-4227</a>
      </div>
      <div class="hero-stats">
        <div class="stat">
          <strong>38m</strong>
          <span>Boom Reach</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <strong>DFW + Tyler</strong>
          <span>Service Area</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <strong>Owner-Operated</strong>
          <span>Every Job</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust Bar -->
  <div class="trust-bar">
    <div class="container trust-inner">
      <div class="trust-item">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
        Fully Insured & Licensed
      </div>
      <div class="trust-item">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
        Direct Owner Contact
      </div>
      <div class="trust-item">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
        BS Concrete Industry Management
      </div>
      <div class="trust-item">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        Flexible Scheduling incl. Weekends
      </div>
    </div>
  </div>

  <!-- ==============================
       SERVICES
  ============================== -->
  <section id="services" class="section">
    <div class="container">
      <div class="section-header">
        <span class="section-label">What We Do</span>
        <h2>Concrete Pumping for Every Job</h2>
        <p>One 38-meter boom pump handles residential, commercial, and civil pours across the Dallas–Tyler Corridor.</p>
      </div>

      <div class="services-grid">
        <div class="service-card">
          <div class="service-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955a1.126 1.126 0 011.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/></svg>
          </div>
          <h3>Residential</h3>
          <ul>
            <li>House slabs, footings & driveways</li>
            <li>Townhouse & duplex pours</li>
            <li>Multi-unit residential</li>
            <li>Pool surrounds</li>
          </ul>
        </div>

        <div class="service-card service-card--featured">
          <div class="service-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21"/></svg>
          </div>
          <h3>Commercial & Industrial</h3>
          <ul>
            <li>Tilt-panel construction</li>
            <li>Warehouse & factory floors</li>
            <li>Data centres & industrial sites</li>
            <li>Commercial developments</li>
          </ul>
        </div>

        <div class="service-card">
          <div class="service-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 004.486-6.336l-3.276 3.277a3.004 3.004 0 01-2.25-2.25l3.276-3.276a4.5 4.5 0 00-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437l1.745-1.437m6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008z"/></svg>
          </div>
          <h3>Civil & Structural</h3>
          <ul>
            <li>Retaining walls & pits</li>
            <li>Culverts & civil infrastructure</li>
            <li>Structural pours</li>
            <li>Retention structures</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ==============================
       ABOUT
  ============================== -->
  <section id="about" class="section section--alt">
    <div class="container">
      <div class="section-header">
        <span class="section-label">About</span>
        <h2>Meet Jacob Gordon</h2>
        <p>Not just an operator — a concrete professional with the degree and industry experience to back it up.</p>
      </div>

      <div class="about-grid">
        <div class="about-main">
          <div class="about-headshot-row">
            <img src="/gordon-concrete-pumping/jacob.jpg" alt="Jacob Gordon" class="headshot" />
            <div class="headshot-info">
              <h3>Jacob Gordon</h3>
              <p>Owner & Operator<br/>Gordon Concrete Pumping<br/>Rockwall, TX</p>
            </div>
          </div>
          <p>
            Gordon Concrete Pumping is owned and operated by Jacob Gordon out of Rockwall, TX.

            Every job is run personally by Jacob — no dispatchers, no subcontracted operators.
            When you book, you deal directly with the person driving the truck.
          </p>
          <p>
            Jacob is currently completing a <strong>BS in Concrete Industry Management at Texas State University</strong>
            (May 2026) — one of the most specialised concrete degrees available in the United States — while
            simultaneously working as a Lab Instructor for CIM 3420 Properties and Testing, preparing students
            for the ACI Field Grade I Exam.
          </p>
          <p>
            His internship background spans ready mix operations at Heidelberg Materials, quality control
            field testing at Centex Materials, and aggregate engineering — giving him a working understanding
            of the full concrete supply chain that most pump operators simply don't have.
          </p>

          <div class="why-matters">
            <h4>What This Means on Your Job</h4>
            <div class="wm-points">
              <div class="wm-point">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
                Understands mix design and how it affects pumpability
              </div>
              <div class="wm-point">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
                ACI-trained — knows what good concrete looks like in the field
              </div>
              <div class="wm-point">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
                Operations background across DFW and Texas concrete industry
              </div>
              <div class="wm-point">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
                Dedicated concrete degree — not a general construction background
              </div>
            </div>
          </div>
        </div>

        <div class="about-credentials">
          <div class="edu-card">
            <div class="edu-card-header">
              <div class="edu-badge">TSU</div>
              <div>
                <strong>Texas State University</strong>
                <span>San Marcos, TX</span>
              </div>
              <span class="edu-dates">2023–2026</span>
            </div>
            <div class="edu-degree">BS Concrete Industry Management</div>
            <p>One of the only dedicated concrete degrees in the US. Covers mix design, materials science, QC, and construction operations.</p>
          </div>

          <div class="exp-cards">
            <div class="exp-mini">
              <div class="exp-mini-role">Lab Instructor — Properties & Testing</div>
              <div class="exp-mini-co">Texas State University · 2025–Present</div>
            </div>
            <div class="exp-mini">
              <div class="exp-mini-role">Ready Mix Intern, Operations</div>
              <div class="exp-mini-co">Heidelberg Materials, Houston · 2025</div>
            </div>
            <div class="exp-mini">
              <div class="exp-mini-role">Ready Mix Intern, Quality Control</div>
              <div class="exp-mini-co">Centex Materials, Austin · 2024–2025</div>
            </div>
            <div class="exp-mini">
              <div class="exp-mini-role">Aggregate Engineering Intern</div>
              <div class="exp-mini-co">Heidelberg Materials, Ennis · 2024</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ==============================
       SERVICE AREA
  ============================== -->
  <section id="service-area" class="section">
    <div class="container">
      <div class="section-header">
        <span class="section-label">Where We Work</span>
        <h2>Dallas–Tyler Corridor</h2>
        <p>Covering the DFW Metroplex and Tyler/East Texas via the I-20 corridor — one of the strongest construction territories in the US.</p>
      </div>

      <div class="area-grid">
        <div class="area-card">
          <div class="area-card-header">
            <h3>Dallas–Fort Worth Metroplex</h3>
            <span class="area-badge">Primary Market</span>
          </div>
          <p>The core of our territory. DFW is ranked <strong>#2 in the US</strong> for new home builder permit volume and <strong>#1 nationally</strong> for industrial permits — with a booming pipeline of data centres, warehouse construction, and commercial development.</p>
          <div class="area-tags">
            {['Dallas', 'Fort Worth', 'Rockwall', 'Mesquite', 'Garland', 'Arlington', 'Plano', 'Frisco', 'McKinney', 'Irving', 'Grand Prairie', 'Richardson', 'Allen', 'Denton', 'Lewisville', 'Carrollton'].map(city => (
              <span class="area-tag">{city}</span>
            ))}
          </div>
        </div>

        <div class="area-card">
          <div class="area-card-header">
            <h3>Tyler & East Texas</h3>
            <span class="area-badge area-badge--secondary">Secondary Market</span>
          </div>
          <p>Far fewer boom pump operators are locally based in Tyler — making it a strong opportunity for relationship-first operators. Jobs are batched to a minimum of 2 per trip. Contact us early to coordinate scheduling.</p>
          <div class="area-tags">
            {['Tyler', 'Longview', 'Lindale', 'Whitehouse', 'Bullard', 'Flint', 'Mineola', 'Canton', 'Terrell', 'Forney', 'Kaufman'].map(city => (
              <span class="area-tag">{city}</span>
            ))}
          </div>
          <div class="area-note">
            Tyler trips require a minimum of 2 jobs per visit at current diesel prices.
          </div>
        </div>
      </div>

      <div class="market-stats">
        <div class="mkt-stat">
          <div class="mkt-stat-value">$50.33B</div>
          <div class="mkt-stat-label">Texas Construction Spending — Leads the Nation</div>
        </div>
        <div class="mkt-stat">
          <div class="mkt-stat-value">#2</div>
          <div class="mkt-stat-label">DFW New Home Permit Volume, Nationally</div>
        </div>
        <div class="mkt-stat">
          <div class="mkt-stat-value">#1</div>
          <div class="mkt-stat-label">DFW Industrial Permits — ~1/3 of TX commercial sq ft</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ==============================
       CONTACT
  ============================== -->
  <section id="contact" class="section section--alt">
    <div class="container">
      <div class="section-header">
        <span class="section-label">Get in Touch</span>
        <h2>Request a Quote</h2>
        <p>Call or fill in the form below. You'll hear back from Jacob directly.</p>
      </div>

      <div class="contact-layout">
        <div class="contact-info">
          <div class="contact-method">
            <div class="contact-method-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>
            </div>
            <div>
              <strong>Phone / Text</strong>
              <a href="tel:+14697044227">(469) 704-4227</a>
              <span>Fastest way to book — call or text Jacob directly</span>
            </div>
          </div>

          <div class="contact-method">
            <div class="contact-method-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
            </div>
            <div>
              <strong>Email</strong>
              <a href="mailto:Jacob@gordonconcrete.com">Jacob@gordonconcrete.com</a>
              <span>For quotes and project details</span>
            </div>
          </div>

          <div class="contact-method">
            <div class="contact-method-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
            </div>
            <div>
              <strong>Based in</strong>
              <span>Rockwall, TX</span>
              <span>Serving Dallas–Fort Worth & Tyler</span>
            </div>
          </div>

          <div class="checklist-box">
            <h4>Have Ready When You Call</h4>
            <ul>
              <li>Site address or suburb</li>
              <li>Estimated pour volume (cubic yards)</li>
              <li>Type of pour (slab, floor, wall, etc.)</li>
              <li>Preferred date</li>
              <li>Ready-mix supplier you're using</li>
            </ul>
          </div>
        </div>

        <form class="quote-form" name="quote-request" method="POST" action="#contact">
          <div class="form-row">
            <div class="form-group">
              <label for="name">Your Name *</label>
              <input type="text" id="name" name="name" placeholder="John Smith" required />
            </div>
            <div class="form-group">
              <label for="phone">Phone Number *</label>
              <input type="tel" id="phone" name="phone" placeholder="(XXX) XXX-XXXX" required />
            </div>
          </div>
          <div class="form-group">
            <label for="email">Email Address</label>
            <input type="email" id="email" name="email" placeholder="your@email.com" />
          </div>
          <div class="form-row">
            <div class="form-group">
              <label for="site-address">Site Address / Suburb *</label>
              <input type="text" id="site-address" name="site_address" placeholder="Dallas, TX" required />
            </div>
            <div class="form-group">
              <label for="pour-date">Preferred Pour Date *</label>
              <input type="date" id="pour-date" name="pour_date" required />
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label for="pour-type">Type of Pour *</label>
              <select id="pour-type" name="pour_type" required>
                <option value="" disabled selected>Select type...</option>
                <option>Residential Slab / Footing</option>
                <option>Driveway / Path</option>
                <option>Townhouse / Duplex / Multi-Unit</option>
                <option>Commercial / Industrial Floor</option>
                <option>Tilt-Panel Construction</option>
                <option>Pool Surround</option>
                <option>Retaining Wall</option>
                <option>Civil / Structural</option>
                <option>Other</option>
              </select>
            </div>
            <div class="form-group">
              <label for="pour-volume">Estimated Volume (yd³)</label>
              <input type="number" id="pour-volume" name="pour_volume" placeholder="e.g. 30" min="1" />
            </div>
          </div>
          <div class="form-group">
            <label for="message">Additional Details</label>
            <textarea id="message" name="message" rows="3" placeholder="Site access notes, concrete supplier, any other details..."></textarea>
          </div>
          <button type="submit" class="btn btn-primary btn-submit">Send Quote Request</button>
          <p class="form-note">We respond within a few hours. For urgent jobs, call directly.</p>
        </form>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* ==============================
     HERO
  ============================== */
  .hero {
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 60%, #0a1f35 100%);
    color: #fff;
    padding: 6rem 1.5rem 5rem;
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/svg%3E");
  }

  .hero-inner { position: relative; max-width: 700px; }

  .hero h1 { color: #fff; margin: 0.75rem 0 1.25rem; }

  .hero-sub {
    font-size: 1.15rem;
    color: rgba(255,255,255,0.85);
    margin-bottom: 2rem;
    max-width: 580px;
  }

  .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 2.5rem; }

  .hero-stats { display: flex; align-items: center; gap: 1.5rem; flex-wrap: wrap; }

  .stat { display: flex; flex-direction: column; }
  .stat strong { font-size: 1.4rem; font-weight: 800; color: var(--color-accent); line-height: 1; }
  .stat span { font-size: 0.78rem; color: rgba(255,255,255,0.6); margin-top: 0.2rem; }
  .stat-divider { width: 1px; height: 36px; background: rgba(255,255,255,0.2); }

  /* Trust Bar */
  .trust-bar { background: var(--color-accent); color: #fff; padding: 0.85rem 1.5rem; }
  .trust-inner { display: flex; justify-content: center; flex-wrap: wrap; gap: 1.5rem; }
  .trust-item { display: flex; align-items: center; gap: 0.4rem; font-size: 0.875rem; font-weight: 600; }

  /* ==============================
     SERVICES
  ============================== */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .service-card {
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    padding: 2rem;
    box-shadow: var(--shadow);
    border-top: 3px solid var(--color-border);
  }

  .service-card--featured {
    border-top-color: var(--color-accent);
    box-shadow: var(--shadow-lg);
  }

  .service-icon {
    color: var(--color-accent);
    margin-bottom: 1rem;
  }

  .service-card h3 {
    color: var(--color-primary);
    margin-bottom: 0.75rem;
    font-size: 1.1rem;
  }

  .service-card ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .service-card li {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    display: flex;
    gap: 0.4rem;
  }

  .service-card li::before { content: '—'; color: var(--color-accent); flex-shrink: 0; }

  /* ==============================
     ABOUT
  ============================== */
  .about-grid {
    display: grid;
